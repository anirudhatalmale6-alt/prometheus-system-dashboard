{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Minimal system dashboard — Backup status + per-node DISK / CPU / RAM.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Immich Backups",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "$ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "FAIL", "color": "red", "index": 1 },
                "1": { "text": "OK", "color": "green", "index": 0 }
              }
            }
          ],
          "unit": "none",
          "noValue": "NO DATA"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "text": { "titleSize": 16, "valueSize": 60 }
      },
      "title": "Immich Backup Age",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$ds" },
          "expr": "(time() - backup_timestamp) < bool 86400",
          "legendFormat": "{{host}}",
          "instant": true,
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 10,
      "title": "Server Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "$ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF9830", "value": null }
            ]
          },
          "unit": "bytes",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 7 },
      "id": 20,
      "maxPerRow": 3,
      "repeat": "instance",
      "repeatDirection": "h",
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "text": { "titleSize": 20, "valueSize": 30 }
      },
      "title": "DISK — $instance",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$ds" },
          "expr": "node_filesystem_size_bytes{instance=\"$instance\", fstype=~\"ext.*|xfs|btrfs\", mountpoint=\"/\"} - node_filesystem_avail_bytes{instance=\"$instance\", fstype=~\"ext.*|xfs|btrfs\", mountpoint=\"/\"}",
          "legendFormat": "Used",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#1f77b4", "value": null },
              { "color": "#EAB839", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 11 },
      "id": 30,
      "maxPerRow": 3,
      "repeat": "instance",
      "repeatDirection": "h",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "text": { "titleSize": 20, "valueSize": 30 }
      },
      "title": "CPU — $instance",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$ds" },
          "expr": "100 - (avg by(instance) (irate(node_cpu_seconds_total{instance=\"$instance\", mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "$ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#1f77b4", "value": null },
              { "color": "#EAB839", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 16 },
      "id": 40,
      "maxPerRow": 3,
      "repeat": "instance",
      "repeatDirection": "h",
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "text": { "titleSize": 20, "valueSize": 30 }
      },
      "title": "RAM — $instance",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$ds" },
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{instance=\"$instance\"} / node_memory_MemTotal_bytes{instance=\"$instance\"}))",
          "legendFormat": "RAM %",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["prometheus", "node-exporter", "system", "minimal", "backup"],
