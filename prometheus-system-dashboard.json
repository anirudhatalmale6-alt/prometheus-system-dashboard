          { "selected": false, "text": "backup", "value": "backup" },
          { "selected": false, "text": "backup-remote", "value": "backup-remote" }
        ],
        "query": "immich,backup,backup-remote",
        "skipUrlSync": false,
        "type": "custom",
        "label": "Node"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
